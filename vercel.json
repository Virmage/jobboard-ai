{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/cron/scan",
      "schedule": "0 */6 * * *"
    }
  ],
  "functions": {
    "src/app/api/mcp/**/*.ts": {
      "maxDuration": 30
    },
    "src/app/api/v1/**/*.ts": {
      "maxDuration": 15
    },
    "src/app/api/employers/**/*.ts": {
      "maxDuration": 15
    },
    "src/app/api/cron/**/*.ts": {
      "maxDuration": 300
    }
  }
}
