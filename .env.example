# Database (Neon / Postgres)
DATABASE_URL=postgresql://user:password@host:5432/jobboard_ai

# Redis (BullMQ queues, rate limiting)
REDIS_URL=redis://localhost:6379

# Stripe (featured listings payments)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Auth (employer sessions)
JWT_SECRET=generate-a-random-64-char-string-here

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
AGENTJOBS_API_URL=http://localhost:3000
NODE_ENV=development

# Scanner (job scraping sources)
SCANNER_CONCURRENCY=5
SCANNER_CUTOFF_DAYS=14
